NEXT_PUBLIC_APP_NAME="Mobile-first Next.js Starter"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
PORT=3000

# Helius / Yellowstone gRPC streaming
HELIUS_RPC_URL="https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY"
HELIUS_GRPC_ENDPOINT="https://mainnet.helius-rpc.com"
HELIUS_API_KEY="YOUR_HELIUS_API_KEY"
SOLANA_COMMITMENT="confirmed"

# Watched wallets, mints, and DEX/aggregator programs. Comma-separated.
WATCHED_WALLETS=""
WATCHED_MINTS="So11111111111111111111111111111111111111112,EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v,Es9vMFrzaCERmJfrF4H2FYD4Yz4vZfM8UQ3W9v2VvT"
DEX_PROGRAMS="675kPX9MHTjS2zt1qfr1NYHuzeLXfQM9H24wFSUt1Mp8,CAMMCzo5YL8w4VFF8KVHrK22GGUQpMpTFb6xRmpLFGNn,JUP6LkbZbjS1jKKwapdHNy74zcZ3tLUZoi5QNyVTaV4"
INCLUDE_FAILED_TRANSACTIONS="true"
MAX_RECENT_EVENTS="500"

# Jito MEV block engine. Bundle submission requires an authorized Jito auth keypair.
JITO_BLOCK_ENGINE_URL="mainnet.block-engine.jito.wtf"
JITO_AUTH_KEYPAIR_PATH="./keys/jito-auth.json"
JITO_TIP_LAMPORTS="100000"

# Optional API protection for POST routes.
BOT_API_TOKEN=""
BOT_AUTO_START="false"
